{
	"name": "sjabloon",
	"version": "0.4.0",
	"description": "Tiny, CSP-safe template engine for JavaScript, powered by xprsn expressions. No eval, no new Function.",
	"repository": "robinvdvleuten/sjabloon",
	"license": "MIT",
	"author": {
		"name": "Robin van der Vleuten",
		"email": "robin@webstronauts.com",
		"url": "https://robinvdvleuten.nl"
	},
	"type": "module",
	"source": "src/index.js",
	"main": "dist/index.cjs",
	"module": "dist/index.js",
	"types": "index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist",
		"src",
		"index.d.ts"
	],
	"size-limit": [
		{
			"path": "dist/index.js",
			"limit": "1.25 kB"
		},
		{
			"path": "dist/index.cjs",
			"limit": "1.25 kB"
		}
	],
	"scripts": {
		"bench": "node bench/index.js",
		"build": "tsdown",
		"prepublishOnly": "npm run build",
		"size": "size-limit",
		"test": "node --disallow-code-generation-from-strings node_modules/tape/bin/tape test/*.test.js"
	},
	"keywords": [
		"template",
		"template-engine",
		"csp",
		"render",
		"handlebars"
	],
	"dependencies": {
		"xprsn": "^0.4.0"
	},
	"devDependencies": {
		"@size-limit/file": "^12.1.0",
		"size-limit": "^12.1.0",
		"tape": "^5.9.0",
		"tsdown": "^0.22.12"
	}
}
